# =============================================================================
# SOCIAL AI MANAGER - Variables de entorno
# Copiar a .env y completar los valores antes de levantar el stack.
# =============================================================================

# --- General ---
APP_NAME=Social AI Manager
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# --- Base de datos (PostgreSQL) ---
POSTGRES_USER=social_manager
POSTGRES_PASSWORD=social_manager_secret
POSTGRES_DB=social_manager
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# Coolify: pegar la URL interna del recurso PostgreSQL. Si viene como postgres:// se normaliza automáticamente.
# Ejemplo Coolify: postgres://user:pass@postgresql-xxx:5432/social_manager

# Migraciones automáticas al arrancar el backend (recomendado en Coolify)
RUN_MIGRATIONS=true
# Seed de datos demo (solo primera instalación local)
RUN_SEED=false

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# --- JWT / Auth ---
JWT_SECRET=change-me-jwt-secret-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Cifrado (tokens OAuth / redes sociales) - AES-256 requiere 32 bytes en base64 ---
ENCRYPTION_KEY=change-me-32-byte-base64-encoded-key-here==

# --- Meta / Instagram Graph API ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/social/instagram/callback
META_GRAPH_API_VERSION=v21.0
# Token de prueba (opcional en desarrollo; en producción usar OAuth por usuario)
META_ACCESS_TOKEN=

# --- Proveedores IA ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
NANO_BANANA_API_KEY=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- CORS (separar múltiples orígenes con coma) ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js - prefijo NEXT_PUBLIC_ expuesto al cliente) ---
# Local con Docker: dejar vacío para proxy /api → backend (ver next.config.js).
# Producción/Coolify: URL pública del backend, ej. https://api.tudominio.com
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=Social AI Manager
